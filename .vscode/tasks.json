{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "RenderCV: Watch Resume",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "rendercv render --watch Jesse_Black_Resume.yaml"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "windows": {
        "command": "wsl.exe",
        "args": [
          "-e",
          "bash",
          "-lc",
          "rendercv render --watch Jesse_Black_Resume.yaml"
        ]
      },
      "isBackground": true,
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
